<!--
This policy validate content and sign of Keycloak SRTP JWT token
-->
<fragment>
  <validate-jwt header-name="Authorization" failed-validation-httpcode="401" require-expiration-time="true" require-scheme="Bearer" require-signed-tokens="true" output-token-variable-name="srtpToken">
    <openid-config url="${mc_shared_base_url}/.well-known/openid-configuration" />
    <issuers>
      <issuer>${mc_shared_base_url}</issuer>
    </issuers>
  </validate-jwt>
  <set-header name="X-JWT-Subject" exists-action="override">
    <value>@(((Jwt)context.Variables["srtpToken"]).Claims.GetValueOrDefault("sub"))</value>
  </set-header>
</fragment>
