<!--
This policy validate content and sign of Keycloak SRTP JWT token
-->
<fragment>
  <validate-jwt header-name="Authorization" failed-validation-httpcode="401"
    require-expiration-time="true" require-scheme="Bearer" require-signed-tokens="true"
    output-token-variable-name="srtpToken">
    <openid-config url="${mc_shared_base_url}/.well-known/openid-configuration" />
    <issuers>
      <issuer>${mc_shared_base_url}</issuer>
    </issuers>
  </validate-jwt>
  <choose>
    <when condition="@(((Jwt)context.Variables[&quot;srtpToken&quot;]).Claims.GetValueOrDefault(&quot;realm_access&quot;, new string[] {&quot;&quot;})[0].Contains(&quot;\&quot;${rtp_group_name}\&quot;&quot;))">
    </when>
    <otherwise>
      <return-response>
        <set-status code="403" reason="Forbidden" />
        <set-body>Missing required role in realm_access.roles</set-body>
      </return-response>
    </otherwise>
  </choose>
</fragment>
